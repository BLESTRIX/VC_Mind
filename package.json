{
  "name": "vc-brain-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "predev": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/free-port.ps1 -Port 3001",
    "dev": "node --env-file=.env --import tsx --watch src/server/index.ts",
    "dev:all": "concurrently --kill-others --names backend,frontend \"npm run dev\" \"npm --prefix frontend run dev\"",
    "start": "tsx --env-file=.env src/server/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run src/tests/unit",
    "test:integration": "vitest run src/tests/integration",
    "lint": "tsc --noEmit",
    "jobs:run-next": "tsx --env-file=.env src/server/jobs/worker.ts --once",
    "jobs:drain": "tsx --env-file=.env src/server/jobs/worker.ts --drain"
  },
  "dependencies": {
    "@fastify/multipart": "^9.2.1",
    "@supabase/supabase-js": "^2.57.4",
    "fastify": "^5.6.1",
    "p-limit": "^7.1.1",
    "pdfjs-dist": "^5.4.149",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/node": "^24.7.2",
    "concurrently": "^10.0.3",
    "kill-port": "^2.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
